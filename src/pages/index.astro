---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getPermalink } from '~/utils/permalinks';
import showroomData from '~/data/showroom.json';

const metadata = {
  title: 'Jay Bhavani Furniture — Premium Furniture Showroom in Navsari',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Visit Showroom',
        href: showroomData.mapUrl,
        target: '_blank',
        icon: 'tabler:map-pin',
      },
      { text: 'Contact Us', href: getPermalink('/contact') },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Premium Furniture Hero Image',
    }}
  >
    <Fragment slot="title">
      Premium Furniture for <span class="hidden xl:inline">your</span>
      <span class="text-accent dark:text-white"> Modern Home</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Jay Bhavani Furniture</span> is a trusted furniture showroom and manufacturer in Navsari
        since {showroomData.foundedYear}.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-orange-600">Jay Bhavani Furniture</span>
      Custom living room, bedroom, dining, and office furniture with exceptional local craftsmanship.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Our Expertise"
    title="What we offer at JBF"
    subtitle="Discover a wide range of premium quality furniture designed to elevate your living spaces."
    items={[
      {
        title: 'Living Room Sets',
        description:
          'Elegant and comfortable sofas, coffee tables, and TV units tailored for modern and classic interiors.',
        icon: 'tabler:sofa',
      },
      {
        title: 'Bedroom Furniture',
        description: 'Luxurious beds, spacious wardrobes, and stylish dressers for your perfect personal sanctuary.',
        icon: 'tabler:bed',
      },
      {
        title: 'Dining Tables',
        description: 'Sturdy and beautiful dining sets crafted to bring families together over memorable meals.',
        icon: 'tabler:box-margin',
      },
      {
        title: 'Office Desks & Chairs',
        description: 'Ergonomic and professional office furniture designed for comfort and high productivity.',
        icon: 'tabler:desk',
      },
      {
        title: 'Custom Craftsmanship',
        description: 'Bespoke furniture solutions built exactly to your specifications and spatial requirements.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Premium Materials',
        description:
          'We source only the finest woods, fabrics, and materials ensuring durability and timeless elegance.',
        icon: 'tabler:diamond',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Why choose us"
    title={`Crafting memories since ${showroomData.foundedYear}`}
    items={[
      {
        title: 'Decades of Trust',
        description: `Over ${new Date().getFullYear() - showroomData.foundedYear} years of serving the Navsari community with unmatched quality and service.`,
      },
      {
        title: 'Local Manufacturing',
        description:
          'We manufacture our products locally, ensuring tight quality control and supporting local artisans.',
      },
      {
        title: 'Customer Satisfaction',
        description: 'Our commitment is to your happiness. We offer excellent after-sales service and guarantees.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1524758631624-e2822e304c36?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Furniture Craftsmanship',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Heritage of Excellence</h3>
      Experience furniture that stands the test of time, both in durability and style.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Latest from our Blog"
    information={`Stay updated with the latest trends in interior design, furniture care tips, and news from the Jay Bhavani Furniture showroom.
                `}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Directions',
        href: showroomData.mapUrl,
        target: '_blank',
        icon: 'tabler:map',
      },
      {
        variant: 'secondary',
        text: 'Contact via WhatsApp',
        href: showroomData.whatsappUrl,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title"> Visit our Showroom Today </Fragment>

    <Fragment slot="subtitle">
      Explore our latest collections at {showroomData.address}.<br class="hidden md:inline" />
      Open {showroomData.hours[0].day}, {showroomData.hours[0].time}.
    </Fragment>
  </CallToAction>
</Layout>
