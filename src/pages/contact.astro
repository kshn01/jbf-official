---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import showroomData from '~/data/showroom.json';

const metadata = {
  title: 'Contact us',
  description:
    'Visit Jay Bhavani Furniture in Navsari or reach us via phone, email, or WhatsApp. Find our location and business hours here.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Visit our Showroom"
    subtitle="We'd love to help you find the perfect furniture. Come visit us or get in touch below."
  />

  <!-- Contact Details -->
  <Features2
    title="Get in touch"
    columns={2}
    items={[
      {
        title: 'Phone',
        description: `<a href="tel:${showroomData.phoneTel}" class="text-orange-500 hover:underline font-semibold">${showroomData.phone}</a>`,
        icon: 'tabler:headset',
      },
      {
        title: 'WhatsApp',
        description: `<a href="${showroomData.whatsappUrl}" target="_blank" rel="noopener" class="text-orange-500 hover:underline font-semibold">Chat on WhatsApp</a>`,
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Email',
        description: `<a href="mailto:${showroomData.email}" class="text-orange-500 hover:underline">${showroomData.email}</a>`,
        icon: 'tabler:mail',
      },
      {
        title: 'Address',
        description: showroomData.address,
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Business Hours -->
  <section class="mx-auto max-w-4xl px-6 py-10">
    <h2 class="text-2xl font-bold text-center mb-6 dark:text-white">Business Hours</h2>
    <div class="overflow-hidden rounded-xl border border-gray-200 dark:border-slate-700">
      {
        showroomData.hours.map((slot, i) => (
          <div
            class:list={[
              'flex justify-between px-6 py-4 text-sm font-medium',
              i % 2 === 0 ? 'bg-white dark:bg-slate-900' : 'bg-orange-50 dark:bg-slate-800',
            ]}
          >
            <span class="text-slate-700 dark:text-slate-300">{slot.day}</span>
            <span class="text-orange-600 dark:text-orange-400 font-semibold">{slot.time}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Map + Directions -->
  <section class="mx-auto max-w-4xl px-6 pb-16">
    <h2 class="text-2xl font-bold text-center mb-6 dark:text-white">Find Us</h2>
    <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-slate-700">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3734.4!2d72.9506!3d20.9467!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be0c5da2d2f0001%3A0x1!2sJay+Bhavani+Furniture%2C+Navsari!5e0!3m2!1sen!2sin!4v1718689000000!5m2!1sen!2sin"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Jay Bhavani Furniture location on Google Maps"></iframe>
    </div>
    <div class="text-center mt-6">
      <a
        href={showroomData.mapUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-3 rounded-full transition-colors duration-200 shadow-md"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path><circle
            cx="12"
            cy="9"
            r="2.5"></circle>
        </svg>
        Get Directions
      </a>
    </div>
  </section>
</Layout>
