---
import BaseLayout from '../layouts/BaseLayout.astro';
import showroom from '../data/showroom.json';

const title = 'Contact Jay Bhavani Furniture';
const description = 'Visit Jay Bhavani Furniture on Abrama Road, Navsari. Call for custom furniture inquiries or view our verified Google Maps location.';
const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout title={title} description={description} image={`${baseUrl}assets/hero-illustration.svg`} url={`${baseUrl}contact/`} showroom={showroom}>
  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr] lg:items-start">
      {/* Left Panel: Form & Intro */}
      <div class="space-y-10">
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-brand-600 font-semibold">Get in touch</p>
          <h1 class="mt-4 text-4xl font-semibold text-slate-900 sm:text-5xl">Let's talk about your space.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
            Have a custom furniture project in mind or want to visit our Navsari showroom? Fill out the form below or reach us directly.
          </p>
        </div>

        {/* Contact Form */}
        <form class="space-y-6" action="#" method="POST" onsubmit="event.preventDefault(); alert('Form submitted! We will get back to you soon.');">
          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <label for="name" class="block text-sm font-medium text-slate-700">Name</label>
              <input type="text" id="name" name="name" required class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="John Doe" />
            </div>
            <div class="space-y-2">
              <label for="phone" class="block text-sm font-medium text-slate-700">Phone</label>
              <input type="tel" id="phone" name="phone" required class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="+91 00000 00000" />
            </div>
          </div>
          <div class="space-y-2">
            <label for="email" class="block text-sm font-medium text-slate-700">Email (Optional)</label>
            <input type="email" id="email" name="email" class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="john@example.com" />
          </div>
          <div class="space-y-2">
            <label for="message" class="block text-sm font-medium text-slate-700">Message</label>
            <textarea id="message" name="message" rows="4" required class="block w-full resize-none rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" placeholder="Tell us about the furniture you're looking for..."></textarea>
          </div>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-brand-500 px-6 py-4 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600 sm:w-auto">
            Send Inquiry
          </button>
        </form>
      </div>

      {/* Right Panel: Details & Map */}
      <div class="space-y-8 lg:mt-4">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-soft">
          <h2 class="text-2xl font-semibold text-slate-900 mb-6">Showroom Information</h2>
          <div class="space-y-6">
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Address</p>
              <p class="mt-2 text-base text-slate-900">{showroom.address}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Phone</p>
                <a href={`tel:${showroom.phoneTel}`} class="mt-2 block text-base font-semibold text-brand-700 hover:text-brand-800">{showroom.phoneDisplay}</a>
              </div>
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">WhatsApp</p>
                <a href={showroom.whatsappUrl} target="_blank" rel="noreferrer" class="mt-2 block text-base font-semibold text-emerald-600 hover:text-emerald-700">Chat on WhatsApp</a>
              </div>
            </div>
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Email</p>
              <a href={`mailto:${showroom.email}`} class="mt-2 block text-base font-semibold text-brand-700 hover:text-brand-800">{showroom.email}</a>
            </div>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Showroom Hours</p>
              <div class="mt-3 space-y-2 text-sm text-slate-700">
                {showroom.hours.map((item) => (
                  <div class="flex justify-between">
                    <span class="font-medium text-slate-900">{item.day}</span>
                    <span>{item.time}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        
        {/* Interactive Google Map Embed & Directions Action */}
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 shadow-soft bg-white">
          <div class="p-2">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3636.1359467057464!2d72.9113964!3d20.9219483!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be0f771b14d4591%3A0x5636432d997cc6e5!2sJay%20Bhavani%20Furniture!5e1!3m2!1sen!2sin!4v1781700480116!5m2!1sen!2sin"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full block rounded-2xl"
            ></iframe>
          </div>
          <div class="flex items-center justify-between border-t border-slate-100 bg-slate-50 px-6 py-4">
            <div>
              <p class="font-semibold text-slate-900">{showroom.name}</p>
              <p class="mt-1 text-sm text-slate-500 line-clamp-1">{showroom.address}</p>
            </div>
            <a href={showroom.mapUrl} target="_blank" rel="noopener noreferrer" class="ml-4 inline-flex shrink-0 items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-100">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Get Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
