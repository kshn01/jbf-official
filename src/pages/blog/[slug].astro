---
import { getCollection, getEntryBySlug } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import showroom from '../../data/showroom.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({ params: { slug: post.slug } }));
}

const post = await getEntryBySlug('blog', Astro.params.slug);
const { Content } = await post.render();
const title = post.data.title;
const description = post.data.description;
const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const socialImage = post.data.heroImage 
  ? (post.data.heroImage.startsWith('http') ? post.data.heroImage : `${baseUrl}${post.data.heroImage.startsWith('/') ? post.data.heroImage.slice(1) : post.data.heroImage}`)
  : `${baseUrl}assets/og-default.svg`;
---

<BaseLayout title={title} description={description} image={socialImage} url={`${baseUrl}blog/${post.slug}/`} showroom={showroom}>
  <section class="mx-auto max-w-5xl px-6 py-20 lg:px-8">
    <div class="space-y-4">
      <p class="text-sm uppercase tracking-[0.32em] text-brand-600">Blog</p>
      <h1 class="text-4xl font-semibold text-slate-900 sm:text-5xl">{post.data.title}</h1>
      <p class="text-sm text-slate-500">Published on {new Date(post.data.pubDate).toLocaleDateString('en-IN', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
      <p class="max-w-3xl text-lg leading-8 text-slate-600">{post.data.description}</p>
    </div>
    <article class="prose prose-slate mt-12 max-w-none prose-headings:font-semibold prose-a:font-semibold prose-a:text-brand-600 hover:prose-a:text-brand-700 prose-img:rounded-2xl dark:prose-invert">
      <Content />
    </article>
  </section>
</BaseLayout>
