---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import showroom from '../../data/showroom.json';

const posts = await getCollection('blog');
const sortedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate));

const title = 'Blog';
const description = 'Furniture design, showroom planning, and home styling articles from Jay Bhavani Furniture in Navsari.';
const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout title={title} description={description} image={`${baseUrl}assets/og-default.svg`} url={`${baseUrl}blog/`} showroom={showroom}>
  <section class="mx-auto max-w-6xl px-6 py-20 lg:px-8">
    <div class="space-y-4 text-center">
      <p class="text-sm uppercase tracking-[0.32em] text-brand-600">Furniture insights</p>
      <h1 class="text-4xl font-semibold text-slate-900 sm:text-5xl">SEO-friendly blog for home design and local furniture buying.</h1>
      <p class="mx-auto max-w-2xl text-base leading-8 text-slate-600">Articles focused on material selection, showroom planning, and building trust with customers in Navsari and Gujarat.</p>
    </div>
    <div class="mt-16 grid gap-6 lg:grid-cols-2">
      {sortedPosts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</BaseLayout>
