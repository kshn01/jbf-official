---
const { showroom } = Astro.props;
const siteUrl = import.meta.env.SITE ?? 'https://jaybhavanifurniture.github.io/jbf-official';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'FurnitureStore',
  name: showroom.name,
  description: showroom.description,
  telephone: showroom.phone,
  email: showroom.email,
  foundingDate: String(showroom.foundedYear),
  address: {
    '@type': 'PostalAddress',
    streetAddress: showroom.address,
    addressLocality: showroom.city,
    addressRegion: showroom.region,
    postalCode: showroom.postalCode,
    addressCountry: 'IN'
  },
  openingHoursSpecification: showroom.openingHours.map((entry) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: entry.days,
    opens: entry.opens,
    closes: entry.closes
  })),
  url: siteUrl,
  sameAs: [showroom.mapUrl]
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
