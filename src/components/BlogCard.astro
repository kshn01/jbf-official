---
const { post } = Astro.props;
const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-soft transition hover:-translate-y-1 hover:shadow-xl">
  <div class="mb-4 flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.24em] text-brand-700">
    {post.data.tags.map((tag) => <span class="rounded-full bg-brand-50 px-3 py-1">{tag}</span>)}
  </div>
  <h3 class="text-2xl font-semibold text-slate-900">{post.data.title}</h3>
  <p class="mt-4 text-sm leading-7 text-slate-600">{post.data.description}</p>
  <div class="mt-6 flex items-center justify-between text-sm text-slate-500">
    <span>{new Date(post.data.pubDate).toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
    <a href={`${baseUrl}blog/${post.slug}/`} class="text-brand-700 font-semibold hover:text-brand-900">Read more</a>
  </div>
</article>
