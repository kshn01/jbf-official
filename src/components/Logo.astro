---
import showroomData from '~/data/showroom.json';

const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const logoUrl = showroomData.logo.startsWith('/') ? showroomData.logo.slice(1) : showroomData.logo;
---

<span
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white flex items-center gap-2"
>
  <img src={`${baseUrl}${logoUrl}`} alt={showroomData.name} class="w-8 h-8 rounded-sm" />
  {showroomData.shortName}
</span>
