---
const { product } = Astro.props;
const rawBase = import.meta.env.BASE_URL ?? '/';
const baseUrl = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const imageSrc = product.image?.startsWith('http')
  ? product.image
  : `${baseUrl}${product.image?.startsWith('/') ? product.image.slice(1) : product.image}`;
---
<article class="group rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft transition hover:-translate-y-1 hover:shadow-xl">
  <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-3xl bg-brand-50">
    <img src={imageSrc} alt="" class="h-10 w-10" />
  </div>
  <h3 class="text-xl font-semibold text-slate-900">{product.title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{product.description}</p>
  <p class="mt-4 text-sm font-medium text-brand-700">{product.highlight}</p>
  <a href={`${baseUrl}contact/?product=${encodeURIComponent(product.title)}`} class="mt-6 inline-flex items-center text-sm font-semibold text-brand-700 transition hover:text-brand-900">
    Inquire about this →
  </a>
</article>
