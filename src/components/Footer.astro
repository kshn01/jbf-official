---
const { showroom } = Astro.props;
const year = new Date().getFullYear();
const experienceYears = year - showroom.foundedYear;
---
<footer class="bg-slate-900 text-slate-200">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-14 md:grid-cols-[1.2fr_0.8fr] lg:px-8">
    <div>
      <p class="text-lg font-semibold text-white">{showroom.name}</p>
      <p class="mt-3 max-w-xl text-sm leading-7 text-slate-300">
        Trusted furniture showroom and manufacturer in Navsari since {showroom.foundedYear}. Custom furniture, expert craftsmanship, and showroom consultations for homes and businesses across Gujarat.
      </p>
      <div class="mt-8 space-y-2 text-sm text-slate-400">
        <p>{showroom.address}</p>
        <p>
          Phone: <a href={`tel:${showroom.phoneTel}`} class="text-brand-300 hover:text-white">{showroom.phoneDisplay}</a>
        </p>
        <p>
          Email: <a href={`mailto:${showroom.email}`} class="text-brand-300 hover:text-white">{showroom.email}</a>
        </p>
      </div>
    </div>
    <div class="space-y-4 text-sm text-slate-300">
      <p class="font-semibold uppercase tracking-[0.18em] text-slate-400">Showroom Hours</p>
      {showroom.hours.map((item) => (
        <div class="flex items-center justify-between rounded-2xl bg-slate-800/70 px-4 py-3">
          <span>{item.day}</span>
          <span class="font-semibold text-white">{item.time}</span>
        </div>
      ))}
      <a
        href={showroom.mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-brand-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Get Directions
      </a>
    </div>
  </div>
  <div class="border-t border-slate-800 px-6 py-6 text-center text-xs text-slate-500 lg:px-8">
    © {year} {showroom.name}. {experienceYears}+ years of craftsmanship in Navsari.
  </div>
</footer>
